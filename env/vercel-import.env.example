# Copy to a local scratch file, fill values, then paste into Vercel → Import .env
# (Or delete these # lines — some parsers skip them; Vercel usually ignores # comments.)

NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
APP_URL=https://YOUR_VERCEL_URL_OR_LOCALHOST
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
# Same values as PAYPAL_* — required in the browser for the subscription JS SDK
NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
NEXT_PUBLIC_PAYPAL_ENV=sandbox
PAYPAL_ENV=sandbox
PAYPAL_MONTHLY_PLAN_ID=P-YOUR_MONTHLY_PLAN_ID
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID
PAYPAL_YEARLY_PLAN_ID=P-YOUR_YEARLY_PLAN_ID
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
