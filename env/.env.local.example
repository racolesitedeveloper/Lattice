# =============================================================================
# Lattice — canonical environment variables
# =============================================================================
# 1. Copy this file to the REPO ROOT as `.env.local` (not inside `env/`).
#    PowerShell:  Copy-Item -Path "env/.env.local.example" -Destination ".env.local"
# 2. Replace every value after the `=` with your real keys/URLs.
# 3. Never commit `.env.local`; keep secrets out of git.
#
# Next.js only loads `.env*` from the project root.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Source: https://supabase.com/dashboard → Project settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# -----------------------------------------------------------------------------
# Application
# Used for PayPal return/cancel URLs. No trailing slash.
# Local: http://localhost:3000  |  Production: https://your-domain.com
# -----------------------------------------------------------------------------
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# PayPal
# Developer: https://developer.paypal.com/dashboard → Apps & Credentials, Webhooks
# Plans: PayPal Business → Pay & Get Paid → Subscription plans (IDs start with P-)
# Webhook URL (HTTPS): https://YOUR_DOMAIN/api/paypal/webhook
# -----------------------------------------------------------------------------
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MONTHLY_PLAN_ID=P-YOUR_MONTHLY_PLAN_ID
PAYPAL_YEARLY_PLAN_ID=P-YOUR_YEARLY_PLAN_ID
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID

# -----------------------------------------------------------------------------
# Optional — LAN / phone against local dev (see next.config.ts)
# Uncomment and set your machine’s IPv4 from `ipconfig`, or use `npm run dev:lan`.
# -----------------------------------------------------------------------------
# NEXT_DEV_LAN_HOST=YOUR_LAN_IPV4
